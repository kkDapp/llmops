# GCP Project
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# GCS
GCS_BUCKET_NAME=your-project-id-rag-docs
GCS_PROCESSED_BUCKET=your-project-id-rag-processed

# Vertex AI
VERTEX_AI_LOCATION=us-central1
EMBEDDING_MODEL=text-embedding-004
LLM_MODEL_FLASH=gemini-1.5-flash-001
LLM_MODEL_PRO=gemini-1.5-pro-001
VECTOR_SEARCH_INDEX_ID=
VECTOR_SEARCH_ENDPOINT_ID=

# BigQuery
BQ_DATASET=rag_analytics
BQ_QUERIES_TABLE=queries
BQ_EVAL_TABLE=evaluations

# Pub/Sub
PUBSUB_TOPIC=rag-ingestion
PUBSUB_SUBSCRIPTION=rag-ingestion-sub

# Redis (Memorystore)
REDIS_HOST=localhost
REDIS_PORT=6379

# ChromaDB (local dev only)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# LLMOps
MLFLOW_TRACKING_URI=http://localhost:5000
MODEL_REGISTRY_NAME=rag-llm
FINE_TUNED_AVAILABLE=false
VLLM_ADAPTER_ENDPOINT=
ENABLE_MLFLOW_LOGGING=true

# Feature flags
USE_VERTEX_VECTOR_SEARCH=false    # true = Vertex AI, false = ChromaDB
USE_DOCUMENT_AI=false             # true = Document AI OCR, false = pypdf
USE_SEMANTIC_CACHE=true
ENABLE_GUARDRAILS=true

# API
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO
