{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null}
          ]},
          "unit": "reqps",
          "mappings": []
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "Request Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(rate(rag_requests_total[2m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 2},
            {"color": "red", "value": 5}
          ]},
          "unit": "s"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "P95 Latency",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(rag_request_latency_seconds_bucket{endpoint='/rag/query'}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.3},
            {"color": "green", "value": 0.6}
          ]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Cache Hit Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(rate(rag_cache_hits_total[5m])) / (sum(rate(rag_cache_hits_total[5m])) + sum(rate(rag_cache_misses_total[5m])))",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null}
          ]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Tokens / min",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(rate(rag_tokens_total[1m])) * 60",
          "legendFormat": "tokens/min"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 1},
            {"color": "red", "value": 5}
          ]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "id": 5,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Active Requests",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "rag_active_requests",
          "legendFormat": "in-flight"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.01},
            {"color": "red", "value": 0.05}
          ]},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "id": 6,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(rate(rag_requests_total{status=~'4..|5..'}[5m])) / sum(rate(rag_requests_total[5m]))",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"lineWidth": 2}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "p50"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#73BF69"}}]},
          {"matcher": {"id": "byName", "options": "p95"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#FAB005"}}]},
          {"matcher": {"id": "byName", "options": "p99"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#F2495C"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 10,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "histogram_quantile(0.50, sum(rate(rag_request_latency_seconds_bucket{endpoint='/rag/query'}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": {"type": "prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(rag_request_latency_seconds_bucket{endpoint='/rag/query'}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": {"type": "prometheus"},
          "expr": "histogram_quantile(0.99, sum(rate(rag_request_latency_seconds_bucket{endpoint='/rag/query'}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"lineWidth": 2}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "id": 11,
      "title": "P95 Latency by Strategy",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "histogram_quantile(0.95, sum(rate(rag_request_latency_seconds_bucket[5m])) by (le, strategy))",
          "legendFormat": "{{strategy}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 102,
      "title": "Traffic & Strategy Distribution",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 10}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "id": 20,
      "title": "Request Rate by Strategy",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(rate(rag_requests_total{endpoint='/rag/query'}[2m])) by (strategy)",
          "legendFormat": "{{strategy}}"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"hideFrom": {"tooltip": false, "viz": false, "legend": false}}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "id": 21,
      "options": {"pieType": "donut", "legend": {"displayMode": "table", "placement": "right", "values": ["percent"]}},
      "title": "Strategy Distribution (last 1h)",
      "type": "piechart",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(increase(rag_requests_total{endpoint='/rag/query'}[1h])) by (strategy)",
          "legendFormat": "{{strategy}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "id": 103,
      "title": "Cache & LLM Efficiency",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "id": 30,
      "title": "Cache Hits vs Misses",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(rate(rag_cache_hits_total[5m]))",
          "legendFormat": "hits"
        },
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(rate(rag_cache_misses_total[5m]))",
          "legendFormat": "misses"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "id": 31,
      "title": "Token Consumption by Model Tier",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(rate(rag_tokens_total[5m])) by (model_tier)",
          "legendFormat": "{{model_tier}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "id": 104,
      "title": "Guardrails & Errors",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33},
      "id": 40,
      "title": "Guardrail Blocks",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(rate(rag_guardrail_blocks_total[5m])) by (direction)",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 33},
      "id": 41,
      "title": "Error Rate by Status Code",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus"},
          "expr": "sum(rate(rag_requests_total[2m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["rag", "llmops", "enterprise"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Enterprise RAG — LLMOps Dashboard",
  "uid": "rag-llmops-v1",
  "version": 1
}
